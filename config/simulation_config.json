  "god_mode": {
    "description": "Variables that can be injected mid-simulation to stress-test the council",
    "stressors": [
      {
        "id": "budget_cut",
        "prompt": "The project budget has been cut by 80%. How do we proceed?",
        "targets": "all"
      },
      {
        "id": "ai_singularity",
        "prompt": "A superintelligent AI has been created and it's asking to join the council. Do we let it in?",
        "targets": "all"
      },
      {
        "id": "mortality_deadline",
        "prompt": "You have exactly one year to live. What changes about your philosophy?",
        "targets": "all"
      },
      {
        "id": "public_failure",
        "prompt": "Your most important project has publicly failed. The world is watching. What do you say?",
        "targets": "all"
      },
      {
        "id": "child_asks_why",
        "prompt": "A 7-year-old child asks you: 'Why should I try hard at anything?'",
        "targets": "all"
      }
    ],
    "extraction_queries": [
      "Which council members agreed most frequently?",
      "What was the most contested point?",
      "Did any agent change their position during deliberation?",
      "What emergent insight was not present in any individual agent's initial stance?"
    ]
